# ----------------------------------------------------------------------------
# DESCRIPTION:      Globalna konfiguracja formatowania kodu dla IDE.
#                   Wymusza spójne wcięcia (4 spacje dla Amber/Just/Shell),
#                   kodowanie UTF-8 oraz uniksowe końce linii (LF).
# ----------------------------------------------------------------------------
# PATH:            .editorconfig
# VERSION:         0.1.0
# CREATED:         2026-07-16
# ============================================================================

# top-most EditorConfig file
root = true

# Wszystkie pliki domyślnie
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# Skrypty Amber, pliki Just, Shell i konfiguracja TOML
[*.{ab,just,sh,bash,zsh,toml}]
indent_style = space
indent_size  = 4

# Główny plik Justfile (nie ma rozszerzenia)
[Justfile]
indent_style = space
indent_size  = 4

# Pliki Markdown (wymagają spacji na końcu linii do łamania wierszy)
[*.md]
trim_trailing_whitespace = false
