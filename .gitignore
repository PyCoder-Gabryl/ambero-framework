# -----------------------------------------------------------------------------
# DESCRIPTION:      Główny plik ignorowanych ścieżek dla systemu Git.
#                   Zoptymalizowany pod systemy UNIX (macOS/Linux) oraz
#                   środowiska JetBrains i VS Code.
# PATH:             .gitignore
# VERSION:          0.1.0
# CREATED:          2026-07-16
# =============================================================================

# =============================================================================
# 1. PLIKI KONFIGURACYJNE AMBERO
# =============================================================================
# Ignorujemy lokalną konfigurację, aby nie wysłać prywatnych ścieżek na GitHuba.
# W repozytorium zostaje tylko szablon: config/config.example.toml
am_config/config.toml

# =============================================================================
# 2. SYSTEMY OPERACYJNE
# =============================================================================

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# --- Linux ---
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# --- Windows (Opcjonalnie, dla kompatybilności) ---
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# =============================================================================
# 3. ŚRODOWISKA PROGRAMISTYCZNE (IDE)
# =============================================================================

# --- JetBrains IDEs (IntelliJ, PyCharm, RustRover, WebStorm itp.) ---
# Ignorujemy pliki specyficzne dla użytkownika i lokalne przestrzenie robocze
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf
.idea/**/aws.xml
.idea/**/contentModel.xml
.idea/**/dataSources/
.idea/**/dataSources.ids
.idea/**/dataSources.local.xml
.idea/**/sqlDataSources.xml
.idea/**/dynamic.xml
.idea/**/uiDesigner.xml
.idea/**/dbnavigator.xml
.idea/**/mongoSettings.xml
.idea/httpRequests
.idea/sonarlint/
.idea
*.iws
out/
*.iml

# --- Visual Studio Code (VS Code) ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# =============================================================================
# 4. PLIKI TYMCZASOWE, LOGI I CACHE, BACKUP
# =============================================================================

*.log
logs/
tmp/
temp/
.cache/
backups/
